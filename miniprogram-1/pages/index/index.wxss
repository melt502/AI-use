/* pages/index/index.wxss - 首页样式 */
.page-container {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
}

/* 顶部装饰背景 */
.header-bg {
  position: absolute;
  top: -120rpx;
  left: -60rpx;
  right: -60rpx;
  height: 480rpx;
  background: linear-gradient(135deg, #07C160 0%, #06AD56 50%, #059648 100%);
  border-radius: 0 0 50% 50%;
  z-index: 0;
}

.header-circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
}

.header-circle-1 {
  width: 200rpx;
  height: 200rpx;
  top: 60rpx;
  right: 80rpx;
}

.header-circle-2 {
  width: 120rpx;
  height: 120rpx;
  top: 180rpx;
  left: 60rpx;
}

/* 主内容 */
.main-content {
  position: relative;
  z-index: 1;
  padding-top: 60rpx;
  padding-bottom: 60rpx;
}

/* 标题区 */
.title-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.title-label {
  font-size: 13px;
  color: rgba(255, 255, 255, 0.85);
  letter-spacing: 4rpx;
  margin-bottom: 12rpx;
}

.title-main {
  font-size: 26px;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 4rpx;
  margin-bottom: 8rpx;
}

.title-sub {
  font-size: 15px;
  color: rgba(255, 255, 255, 0.7);
  font-weight: 500;
  letter-spacing: 6rpx;
}

/* 说明卡片 */
.intro-card {
  margin-top: 20rpx;
}

.intro-item {
  display: flex;
  align-items: center;
  padding: 8rpx 0;
}

.intro-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.intro-icon-clock {
  background-color: #E8F8EF;
}

.intro-icon-list {
  background-color: #E8F5EE;
}

.intro-icon-dim {
  background-color: #E0F2E9;
}

.icon-text {
  font-size: 15px;
  font-weight: 700;
  color: #07C160;
}

.intro-text-wrap {
  display: flex;
  flex-direction: column;
}

.intro-title {
  font-size: 16px;
  font-weight: 600;
  color: #333333;
  margin-bottom: 4rpx;
}

.intro-desc {
  font-size: 13px;
  color: #888888;
  line-height: 1.5;
}

.intro-divider {
  height: 1rpx;
  background-color: #F0F0F0;
  margin: 20rpx 0;
}

/* 维度卡片 */
.dim-card {
  margin-top: 0;
}

.dim-card-title {
  font-size: 15px;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
  display: block;
}

.dim-list {
  display: flex;
  flex-direction: column;
}

.dim-item {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.dim-item:last-child {
  margin-bottom: 0;
}

.dim-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.dim-dot-mood {
  background-color: #F59E0B;
}

.dim-dot-oppose {
  background-color: #EF4444;
}

.dim-dot-school {
  background-color: #3B82F6;
}

.dim-name {
  font-size: 14px;
  color: #555555;
}

/* 按钮容器 */
.btn-wrap {
  padding: 0 32rpx;
}

/* 免责提示 */
.disclaimer {
  margin: 40rpx 32rpx 0;
  padding: 24rpx;
  background-color: #FFF8E1;
  border-radius: 12rpx;
  border-left: 6rpx solid #F59E0B;
}

.disclaimer-text {
  font-size: 12px;
  color: #8D6E00;
  line-height: 1.7;
}

/* 隐私提示 */
.privacy {
  margin: 24rpx 32rpx 0;
  display: flex;
  align-items: center;
}

.privacy-icon-wrap {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background-color: #E8F8EF;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.privacy-icon-text {
  font-size: 11px;
  color: #07C160;
  font-weight: 700;
}

.privacy-text {
  font-size: 12px;
  color: #AAAAAA;
  line-height: 1.6;
}